# ============ 环境配置 ============
ENVIRONMENT=development  # production, development, test

# ============ API配置 ============
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ============ 安全配置 ============
# 生产环境请使用强随机密钥: openssl rand -hex 32
SECRET_KEY=

# ============ JWT配置 ============
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ Cookie配置 ============
COOKIE_SECURE=false  # 生产环境设置为 true
COOKIE_DOMAIN=       # 可选，如 .example.com

# ============ TOTP配置 ============
TOTP_ISSUER=Drexor
TOTP_ENCRYPTION_SALT=

# ============ Redis配置 ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=default
REDIS_USE_SSL=false
REDIS_TIMEOUT=10

# ============ 数据库配置 (PostgreSQL) ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=drexor
DB_ECHO=false

# ============ 日志配置 ============
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ============ 跨域配置 ============
# 多个域名用逗号分隔
CORS_ORIGINS=["*"]

# ============ Worker配置 ============
# API 进程不启动后台任务；需要后台能力时单独运行 make worker。
WORKER_INSTANCE_ID=
WORKER_SHUTDOWN_TIMEOUT_SECONDS=30

# ============ Scheduler配置 ============
# 打开后 make worker 会启动 APScheduler，并只加载 JobConfig.enabled=true 的任务。
SCHEDULER_ENABLED=false
SCHEDULER_LOAD_ONLY_ENABLED_JOBS=true

# ============ Queue Worker配置 ============
# 目前默认关闭；未来有异步消费者时再打开。
# QUEUE_WORKER_CONSUMERS 使用 JSON 数组，例如 ["example"]。
QUEUE_WORKER_ENABLED=false
QUEUE_WORKER_CONSUMERS=[]
